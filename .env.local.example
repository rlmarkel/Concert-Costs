# Concert Cost Tracker — environment variables
#
# 1. Copy this file to .env.local in the same folder as package.json
# 2. Fill in the values below
# 3. Stop the dev server (Ctrl+C) and run: npm run dev
#
# Where to find these values:
# - Open https://supabase.com and sign in
# - Open your ConcertCosts / Concerts project
# - Go to Connect (or Settings → API Keys)
# - Copy the Project URL → NEXT_PUBLIC_SUPABASE_URL
# - Copy the publishable key (or the older "anon" public key if shown)
#   → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# IMPORTANT: Use only the public/publishable (anon) key in this file.
# Never put a service role or secret key in the frontend app.

NEXT_PUBLIC_SUPABASE_URL=https://fbqhjmbvellkbhpeflfk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_public_key_here
